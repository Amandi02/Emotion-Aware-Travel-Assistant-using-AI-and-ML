PORT=3000
MONGODB_URI=mongodb://localhost:27017/feelio
JWT_SECRET=your-super-secret-key-change-in-production
FRONTEND_URL=http://localhost:5173

# ── Unified ML pipeline service (feelio/ml-api) ───────────────────────────────
# Run from feelio/ml-api/: python -m uvicorn main:app --port 8003
# It embeds both the emotion model and the emission model directly.
ML_API_URL=http://127.0.0.1:8003

# ── Google Places API ─────────────────────────────────────────────────────────
GOOGLE_PLACES_API_KEY=your-google-places-api-key

# ── Stripe ────────────────────────────────────────────────────────────────────
STRIPE_SECRET_KEY=sk_test_...
STRIPE_PUBLISHABLE_KEY=pk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...

# Deep-link base used in Stripe success/cancel redirect URLs
APP_SCHEME=feelio://
