# Copy this file to .env and fill in your values

# MongoDB: use your local MongoDB or MongoDB Atlas connection string
MONGODB_URI=mongodb://localhost:27017
MONGODB_DB_NAME=emotion_app

# Hugging Face model: use full ID for download, or path to a local folder
# Default (no need to set): motheecreator/vit-Facial-Expression-Recognition
# EMOTION_MODEL_PATH=motheecreator/vit-Facial-Expression-Recognition

# Server (optional)
HOST=0.0.0.0
PORT=8000
